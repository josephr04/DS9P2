<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutDocumento"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/ivDocumentoIcono"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_document"
        app:tint="@color/primary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvDocumentoNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Documento.pdf"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvDocumentoFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 12, 2023"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvDocumentoTamaño"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.4 MB"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/btnDescargarDocumento"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_download"
        app:tint="@color/primary"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
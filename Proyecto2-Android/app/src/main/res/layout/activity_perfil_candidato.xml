<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/surface"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/primary"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfil del Candidato"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header del Candidato -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp"
                android:background="@color/surface"
                android:elevation="2dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="2dp"
                    app:civ_border_color="@color/primary" />

                <TextView
                    android:id="@+id/tvNombreCandidato"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ana García Méndez"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvPosicionCandidato"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senior Software Engineer"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:id="@+id/tabInfoPersonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@color/surface">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información Personal"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/viewIndicatorInfo"
                        android:layout_width="60dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/primary"
                        android:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabDocumentos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@color/surface">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Documentos"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/viewIndicatorDocs"
                        android:layout_width="60dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/primary"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBarPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                android:indeterminateTint="@color/primary" />

            <!-- Contenido Información Personal -->
            <LinearLayout
                android:id="@+id/layoutInfoPersonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <!-- Personal Information -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Información Personal"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- 2 columnas -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginEnd="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="PRIMER NOMBRE"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvFirstName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Ana"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="PRIMER APELLIDO"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvLastName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="García"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="CÉDULA"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvCedula"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="01-0234-05678"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="FECHA DE NACIMIENTO"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvBirthDate"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="15/05/1994"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="TIPO DE SANGRE"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvBloodType"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="O+"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="SEGUNDO NOMBRE"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvMiddleName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="-"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="SEGUNDO APELLIDO"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvSecondLastName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Méndez"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="GÉNERO"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvGender"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Femenino"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="ESTADO CIVIL"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvMaritalStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Soltero/a"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="12dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="RANGO ACADÉMICO"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary" />
                                    <TextView
                                        android:id="@+id/tvAcademicLevel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Licenciatura"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Contact Information -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Información de Contacto"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="TELÉFONO PRIMARIO"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvPrimaryPhone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="225-4321"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CELULAR PRIMARIO"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvPrimaryCell"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="6789-4321"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="TELÉFONO SECUNDARIO"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvSecondaryPhone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CELULAR SECUNDARIO"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvSecondaryCell"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CORREO ELECTRÓNICO"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="8dp" />
                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ana.garcia@example.com"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Residential Address -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dirección Residencial"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PROVINCIA"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvProvince"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Panamá"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CORREGIMIENTO"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvCorregimiento"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Bella Vista"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CALLE"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvStreet"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Calle 52 Este"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DISTRITO"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvDistrict"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Panamá"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="URBANIZACIÓN"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvUrbanization"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="El Cangrejo"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CASA/EDIFICIO #"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />
                                <TextView
                                    android:id="@+id/tvHouseBuilding"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PH Sky Tower, Apt 402"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DETALLES ADICIONALES"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="12dp" />
                        <TextView
                            android:id="@+id/tvAdditionalDetails"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Behind store X, blue gate."
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Job Application -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Postulación"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VACANTE APLICADA"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tvVacancyApplied"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Desarrollador Frontend Senior"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Contenido Documentos -->
            <LinearLayout
                android:id="@+id/layoutDocumentos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Documentos Subidos"
                                android:textColor="@color/primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvTotalArchivos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4 Files Total"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvDocumentos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
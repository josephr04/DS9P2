<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_briefcase"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="NewWays"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_person"
                    app:civ_border_color="@color/border"
                    app:civ_border_width="1dp" />
            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Page Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Documentos"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestiona y organiza tus certificaciones profesionales de manera eficiente."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- ===== CARD: Subir Nuevo Documento ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subir Nuevo Documento"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Document Title -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Título*" />
                    <EditText
                        android:id="@+id/etTituloDocumento"
                        style="@style/InputField"
                        android:hint="Ej. Certificación AWS Cloud Architect"
                        android:inputType="textCapSentences" />

                    <!-- Type -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Grado Académico" />
                    <Spinner
                        android:id="@+id/spinnerTipo"
                        style="@style/SpinnerField" />

                    <!-- Institución -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Institución *" />
                    <Spinner
                        android:id="@+id/spinnerInstitucion"
                        style="@style/SpinnerField" />

                    <!-- Checkbox institución no en lista -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="-4dp"
                        android:layout_marginBottom="12dp">

                        <CheckBox
                            android:id="@+id/checkInstitucionCustom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/primary"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¿La institución no está en la lista?"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Institución custom (oculto por defecto) -->
                    <EditText
                        android:id="@+id/etInstitucionCustom"
                        style="@style/InputField"
                        android:hint="Nombre de la institución"
                        android:inputType="textCapWords"
                        android:visibility="gone" />

                    <!-- Provincia -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Provincia *" />
                    <Spinner
                        android:id="@+id/spinnerProvincia"
                        style="@style/SpinnerField" />

                    <!-- Fecha de Inicio -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Fecha de Inicio *" />
                    <LinearLayout
                        android:id="@+id/etFechaInicio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_input_field"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvFechaInicio"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="mm/dd/yyyy"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <!-- Fecha de Finalización -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Fecha de Finalización *" />
                    <LinearLayout
                        android:id="@+id/etFechaFin"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_input_field"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvFechaFin"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="mm/dd/yyyy"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <!-- Fecha de Emisión -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Fecha de Emisión *" />
                    <LinearLayout
                        android:id="@+id/etFechaEmision"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_input_field"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvFechaEmision"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="mm/dd/yyyy"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <!-- Total de Horas -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Total de Horas *" />
                    <EditText
                        android:id="@+id/etTotalHoras"
                        style="@style/InputField"
                        android:hint="Ej. 40"
                        android:inputType="number" />

                    <!-- Archivo PDF -->
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Archivo PDF" />

                    <LinearLayout
                        android:id="@+id/layoutUploadPdf"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_upload_area"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivUploadIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_document"
                            app:tint="@color/primary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvUploadLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Arrastra o haz clic para subir"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Solo archivos PDF (Máx. 10MB)"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Botón Subir -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubirDocumento"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="+ Subir Documento"
                        android:textColor="@color/surface"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== Tus Documentos Header ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tus Documentos"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivFiltrar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_filter"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/text_secondary" />

                <ImageView
                    android:id="@+id/ivBuscar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <!-- ===== Estado vacío ===== -->
            <LinearLayout
                android:id="@+id/layoutVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_document"
                    app:tint="@color/border"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No tienes documentos\nsubidos"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sube tu primer certificado para\ncomenzar tu proceso"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- ===== Lista de documentos (se muestra cuando hay docs) ===== -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDocumentos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavPostulante"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        android:paddingTop="8dp"
        app:menu="@menu/menu_bottom_nav_postulante"
        app:itemIconTint="@color/selector_bottom_nav"
        app:itemTextColor="@color/selector_bottom_nav"
        app:elevation="8dp"
        app:itemIconSize="24dp"
        app:labelVisibilityMode="labeled"
        app:itemTextAppearanceActive="@style/BottomNavTextAppearance"
        app:itemTextAppearanceInactive="@style/BottomNavTextAppearance" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>